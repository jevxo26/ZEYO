{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "ts-node --project tsconfig.server.json prisma/seed.ts"
  },
  "scripts": {
    "dev": "nodemon --watch server --watch tsconfig.server.json --ext ts --exec ts-node --project tsconfig.server.json server/index.ts",
    "build": "next build && tsc --project tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server/index.js",
    "lint": "eslint",
    "seed": "prisma db seed --schema=prisma/schema",
    "db:generate": "prisma generate --schema=prisma/schema",
    "db:migrate": "prisma migrate dev --schema=prisma/schema",
    "db:migrate:prod": "prisma migrate deploy --schema=prisma/schema",
    "db:studio": "prisma studio --schema=prisma/schema",
    "db:validate": "prisma validate --schema=prisma/schema"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "@react-oauth/google": "^0.13.5",
    "@reduxjs/toolkit": "^2.12.0",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "framer-motion": "^12.42.2",
    "google-auth-library": "^10.9.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.22.0",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-facebook-login": "^4.1.1",
    "react-hook-form": "^7.80.0",
    "react-icons": "^5.7.0",
    "react-redux": "^9.3.0",
    "react-select": "^5.10.2",
    "recharts": "^3.8.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.6.0",
    "ts-node-dev": "^2.0.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^6.0.2",
    "typeorm": "^1.0.0",
    "yup": "^1.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/internals": "^6.19.3",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-facebook-login": "^4.1.11",
    "@types/twilio": "^3.19.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
