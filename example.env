NODE_ENV=development
PORT=3000

# ─── PostgreSQL (NeonDB) ──────────────────────────────────────────────────────
# Get this from: https://console.neon.tech → Your Project → Connection Details
# Use the "Pooled connection" string for DATABASE_URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require

# Use the "Direct connection" string for DIRECT_URL (used by Prisma migrations)
DIRECT_URL=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require

# ─── MongoDB (Atlas) ──────────────────────────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
# Used for: Logs, Events, Cache, Chat, Queue, Real-time data (Part 17)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxxxx.mongodb.net/zeyo?retryWrites=true&w=majority&appName=Cluster0

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# For Gmail: enable 2FA and use an App Password (not your regular password)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
FROM_EMAIL=your_email@gmail.com
FROM_NAME="ZEYO"

# ─── Twilio SMS ───────────────────────────────────────────────────────────────
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── JWT ─────────────────────────────────────────────────────────────────────
# REQUIRED — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=1d

# JWT Refresh Token
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ─── App URLs ─────────────────────────────────────────────────────────────────
# Frontend URL used in email links (password reset, verification etc.)
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated list of allowed frontend origins
# Example for production: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# ─── Social Auth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
