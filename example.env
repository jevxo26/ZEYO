NODE_ENV=development
PORT=3000

# Database (Neon DB PostgreSQL Connection String)
# Example: postgresql://[user]:[password]@[neon_hostname]/[dbname]?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require

# Email SMTP Config
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
FROM_EMAIL=your_email@gmail.com
FROM_NAME="Your App Name"

# Twilio SMS Config
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# JWT Config (REQUIRED — must be a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=1d

# JWT Refresh Config
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Social Auth
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
