// ─────────────────────────────────────────────────────────────────────────────
// ServiceSetting Model — one-to-one with Service
// Feature flags controlling service behaviour in Calculator & Package
// ─────────────────────────────────────────────────────────────────────────────

model ServiceSetting {
  id                      Int      @id @default(autoincrement())
  serviceId               Int      @unique
  service                 Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  allowCustomization      Boolean  @default(true)
  allowAddon              Boolean  @default(true)
  allowMultipleSelection  Boolean  @default(false)
  allowQuantity           Boolean  @default(false)
  allowDuration           Boolean  @default(true)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([serviceId])
}
