// ─────────────────────────────────────────────────────────────────────────────
// ServiceFAQ Model
// ─────────────────────────────────────────────────────────────────────────────

model ServiceFAQ {
  id           Int      @id @default(autoincrement())
  serviceId    Int
  service      Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  question     String
  answer       String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([serviceId])
  @@index([displayOrder])
}
