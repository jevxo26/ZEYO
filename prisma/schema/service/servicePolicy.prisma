// ─────────────────────────────────────────────────────────────────────────────
// ServicePolicy Model
// ─────────────────────────────────────────────────────────────────────────────

model ServicePolicy {
  id                Int      @id @default(autoincrement())
  serviceId         Int
  service           Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  policyTitle       String
  policyDescription String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([serviceId])
}
