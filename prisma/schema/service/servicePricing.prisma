// ─────────────────────────────────────────────────────────────────────────────
// ServicePricing Model
// Base pricing config for a service (one-to-one)
// pricingType: fixed | hourly | daily | per_head | custom
// ─────────────────────────────────────────────────────────────────────────────

model ServicePricing {
  id           Int      @id @default(autoincrement())
  serviceId    Int      @unique
  service      Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  basePrice    Decimal  @db.Decimal(12, 2)
  minimumPrice Decimal? @db.Decimal(12, 2)
  maximumPrice Decimal? @db.Decimal(12, 2)
  pricingType  String   @default("fixed") // fixed | hourly | daily | per_head | custom
  currency     String   @default("BDT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([serviceId])
}
