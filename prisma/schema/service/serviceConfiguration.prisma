// ─────────────────────────────────────────────────────────────────────────────
// ServiceConfiguration Model
// Smart Calculator fields shown per service (Coverage, Album, Guest Count, Menu)
// fieldType: text | number | select | multiselect | boolean | range
// ─────────────────────────────────────────────────────────────────────────────

model ServiceConfiguration {
  id                Int              @id @default(autoincrement())
  serviceId         Int
  service           Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  configurationName String
  fieldType         String           @default("select") // text | number | select | multiselect | boolean | range
  isRequired        Boolean          @default(false)
  displayOrder      Int              @default(0)
  defaultValue      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  variants          ServiceVariant[]

  @@index([serviceId])
  @@index([displayOrder])
}
