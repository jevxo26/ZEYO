// ─────────────────────────────────────────────────────────────────────────────
// UserOTP Model
// Stores OTPs for phone/email verification, login, password reset, etc.
// Separate from UserToken because OTPs are short-lived, numeric, and rate-limited.
// ─────────────────────────────────────────────────────────────────────────────

model UserOTP {
  id           Int       @id @default(autoincrement())
  userId       Int

  // ── OTP Target ─────────────────────────────────────────────────────────────
  phone        String?
  email        String?

  // ── OTP Data ───────────────────────────────────────────────────────────────
  otp          String    // Stored as hashed value (SHA-256)
  type         String    // login | register | password_reset | phone_verification | email_verification | two_factor

  // ── Lifecycle ──────────────────────────────────────────────────────────────
  expiresAt    DateTime
  verifiedAt   DateTime?
  attemptCount Int       @default(0) // Track failed attempts for rate limiting

  // ── Status ─────────────────────────────────────────────────────────────────
  status       String    @default("pending") // pending | verified | expired | blocked

  // ── Relations ──────────────────────────────────────────────────────────────
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([phone, type])
  @@index([email, type])
  @@index([status])
}
