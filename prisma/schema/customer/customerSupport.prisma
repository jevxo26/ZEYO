model CustomerSupport {
  id              Int       @id @default(autoincrement())
  customerId      Int
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  ticketNumber    String    @unique
  subject         String
  description     String
  priority        String    @default("low") // e.g. low | medium | high
  status          String    @default("open") // e.g. open | in_progress | resolved | closed
  assignedAdminId Int?
  assignedAdmin   User?     @relation("CustomerSupportAssignedAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([customerId])
  @@index([assignedAdminId])
}
