model CustomerReferral {
  id                 Int      @id @default(autoincrement())
  customerId         Int
  customer           Customer @relation("Referrer", fields: [customerId], references: [id], onDelete: Cascade)
  referralCode       String
  referredCustomerId Int      @unique
  referredCustomer   Customer @relation("Referred", fields: [referredCustomerId], references: [id], onDelete: Cascade)
  rewardAmount       Float    @default(0)
  status             String   @default("pending") // e.g. pending | completed | expired
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([customerId])
}
