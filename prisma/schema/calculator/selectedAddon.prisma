// ─────────────────────────────────────────────────────────────────────────────
// SelectedAddon — optional add-ons chosen by the customer (Drone, Album, Dessert)
// addonId → ServiceAddon
// ─────────────────────────────────────────────────────────────────────────────

model SelectedAddon {
  id                Int             @id @default(autoincrement())
  selectedServiceId Int
  selectedService   SelectedService @relation(fields: [selectedServiceId], references: [id], onDelete: Cascade)
  addonId           Int
  addon             ServiceAddon    @relation(fields: [addonId], references: [id])
  quantity          Int             @default(1)
  unitPrice         Decimal         @db.Decimal(12, 2)
  totalPrice        Decimal         @db.Decimal(12, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([selectedServiceId])
  @@index([addonId])
}
