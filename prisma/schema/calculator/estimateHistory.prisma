// ─────────────────────────────────────────────────────────────────────────────
// EstimateHistory — audit trail of every change to the calculator total
// changes: JSON snapshot of what changed
// ─────────────────────────────────────────────────────────────────────────────

model EstimateHistory {
  id           Int                  @id @default(autoincrement())
  calculatorId Int
  calculator   SmartEventCalculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)
  version      Int
  totalAmount  Decimal              @db.Decimal(14, 2)
  changes      Json?
  createdAt    DateTime             @default(now())

  @@index([calculatorId])
  @@index([version])
}
