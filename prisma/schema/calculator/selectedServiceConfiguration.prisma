// ─────────────────────────────────────────────────────────────────────────────
// SelectedServiceConfiguration — chosen config value per service (e.g. Coverage = 2 Days)
// configurationId → ServiceConfiguration
// ─────────────────────────────────────────────────────────────────────────────

model SelectedServiceConfiguration {
  id                 Int             @id @default(autoincrement())
  selectedServiceId  Int
  selectedService    SelectedService @relation(fields: [selectedServiceId], references: [id], onDelete: Cascade)
  configurationId    Int
  configuration      ServiceConfiguration @relation(fields: [configurationId], references: [id])
  configurationValue String
  additionalPrice    Decimal?        @db.Decimal(12, 2)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([selectedServiceId, configurationId])
  @@index([selectedServiceId])
  @@index([configurationId])
}
