// ─────────────────────────────────────────────────────────────────────────────
// Settlement — platform-level settlement summary after event completion
// status: pending | calculated | settled | disputed
// ─────────────────────────────────────────────────────────────────────────────

model Settlement {
  id                 Int      @id @default(autoincrement())
  bookingId          Int
  booking            Booking  @relation("settlements", fields: [bookingId], references: [id])
  totalAmount        Decimal  @db.Decimal(12, 2)
  vendorAmount       Decimal  @db.Decimal(12, 2)
  platformCommission Decimal  @db.Decimal(12, 2)
  taxAmount          Decimal  @default(0) @db.Decimal(12, 2)
  netAmount          Decimal  @db.Decimal(12, 2)
  status             String   @default("pending")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  vendorSettlements VendorSettlement[]

  @@index([bookingId])
  @@index([status])
}
