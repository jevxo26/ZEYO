// ─────────────────────────────────────────────────────────────────────────────
// Payment — root payment record created after booking confirmation
// paymentType: full | partial | installment | advance
// paymentStatus: pending | partial | paid | overdue | refunded | cancelled
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id            Int             @id @default(autoincrement())
  bookingId     Int
  booking       Booking         @relation("billingPayments", fields: [bookingId], references: [id])
  customerId    Int
  customer      Customer        @relation("payments", fields: [customerId], references: [id])
  invoiceId     Int?
  paymentInvoice PaymentInvoice? @relation("paymentToInvoice", fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentNumber String          @unique
  paymentType   String          @default("full")
  paymentStatus String          @default("pending")
  currency      String          @default("BDT")
  subtotal      Decimal         @db.Decimal(12, 2)
  discount      Decimal         @default(0) @db.Decimal(12, 2)
  tax           Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal         @db.Decimal(12, 2)
  paidAmount    Decimal         @default(0) @db.Decimal(12, 2)
  dueAmount     Decimal         @db.Decimal(12, 2)
  paymentDate   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  transactions   PaymentTransaction[]
  installments   PaymentInstallment[]
  schedules      PaymentSchedule[]
  receipt        PaymentReceipt?
  verification   PaymentVerification?
  webhooks       PaymentWebhook[]
  refunds        Refund[]
  taxTransactions TaxTransaction[]
  billingAddress BillingAddress?
  history        PaymentHistory[]
  logs           PaymentLog[]

  @@index([bookingId])
  @@index([customerId])
  @@index([paymentStatus])
  @@index([paymentNumber])
}
