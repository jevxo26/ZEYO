// ─────────────────────────────────────────────────────────────────────────────
// UserPreference Model
// Stores user's app-level preferences like theme, budget, event type, zone.
// One-to-one with User.
// NOTE: preferredZoneId and preferredEventTypeId reference future models.
// ─────────────────────────────────────────────────────────────────────────────

model UserPreference {
  id                   Int     @id @default(autoincrement())
  userId               Int     @unique

  // ── Discovery Preferences (FK to future models) ────────────────────────────
  preferredZoneId      Int?    // FK → Zone (pending)
  preferredEventTypeId Int?    // FK → EventType (pending)

  // ── UI & Budget Preferences ────────────────────────────────────────────────
  preferredTheme       String? @default("system") // light | dark | system
  preferredBudget      Float?  // Max budget filter for event browsing

  // ── Localisation (overrides UserProfile values if set) ─────────────────────
  preferredLanguage    String? // bn | en | etc.
  preferredCurrency    String? // BDT | USD | etc.

  // ── Relations ──────────────────────────────────────────────────────────────
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
