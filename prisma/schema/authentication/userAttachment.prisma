// ─────────────────────────────────────────────────────────────────────────────
// UserAttachment Model
// File uploads associated with a user (KYC docs, profile assets, ticket files).
// ─────────────────────────────────────────────────────────────────────────────

model UserAttachment {
  id         Int      @id @default(autoincrement())
  userId     Int

  // ── File Metadata ──────────────────────────────────────────────────────────
  fileName   String             // Original file name
  fileType   String             // image | pdf | video | document | other
  fileUrl    String             // Public or signed URL
  fileSize   Int                // Size in bytes
  mimeType   String?            // e.g. image/jpeg, application/pdf
  context    String?            // Where it was uploaded from: kyc | ticket | profile | etc.

  // ── Relations ──────────────────────────────────────────────────────────────
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Timestamps ─────────────────────────────────────────────────────────────
  uploadedAt DateTime @default(now())

  @@index([userId])
  @@index([context])
}
