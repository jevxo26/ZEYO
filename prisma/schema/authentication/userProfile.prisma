// ─────────────────────────────────────────────────────────────────────────────
// UserProfile Model
// Extended profile info for a User — one-to-one relation.
// Auto-created on user registration. Optional fields only.
// ─────────────────────────────────────────────────────────────────────────────

model UserProfile {
  id     String @id @default(uuid())
  userId Int    @unique

  // ── Relation ───────────────────────────────────────────────────────────────
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Professional Info ──────────────────────────────────────────────────────
  occupation   String?
  companyName  String?
  organization String?
  bio          String?
  website      String?

  // ── Social Links ───────────────────────────────────────────────────────────
  facebook  String?
  instagram String?
  linkedin  String?

  // ── Localisation Preferences ───────────────────────────────────────────────
  preferredLanguage String @default("bn")
  preferredCurrency String @default("BDT")
  timezone          String @default("Asia/Dhaka")

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
