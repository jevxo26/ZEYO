// ─────────────────────────────────────────────────────────────────────────────
// Analytics Config Module
// ─────────────────────────────────────────────────────────────────────────────

model AnalyticsLog {
  id          Int      @id @default(autoincrement())
  module      String
  action      String
  description String   @db.Text
  createdAt   DateTime @default(now())
}

model AnalyticsSetting {
  id                    Int      @id @default(autoincrement())
  refreshInterval       Int      @default(60) // minutes
  defaultDateRange      String   @default("30_days") // 7_days, 30_days, year
  allowExport           Boolean  @default(true)
  allowScheduledReports Boolean  @default(true)
  status                String   @default("active")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
