// ─────────────────────────────────────────────────────────────────────────────
// Analytics Module
// Operational & Business Intelligence Metrics
// ─────────────────────────────────────────────────────────────────────────────

model DashboardAnalytics {
  id                  Int      @id @default(autoincrement())
  dashboardName       String
  totalBookings       Int      @default(0)
  totalRevenue        Decimal  @default(0.00) @db.Decimal(10, 2)
  totalCustomers      Int      @default(0)
  totalVendors        Int      @default(0)
  totalEvents         Int      @default(0)
  averageBookingValue Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BookingAnalytics {
  id                  Int      @id @default(autoincrement())
  bookingDate         DateTime
  totalBookings       Int      @default(0)
  completedBookings   Int      @default(0)
  cancelledBookings   Int      @default(0)
  pendingBookings     Int      @default(0)
  averageBookingValue Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model RevenueAnalytics {
  id                 Int      @id @default(autoincrement())
  date               DateTime
  grossRevenue       Decimal  @default(0.00) @db.Decimal(10, 2)
  netRevenue         Decimal  @default(0.00) @db.Decimal(10, 2)
  platformCommission Decimal  @default(0.00) @db.Decimal(10, 2)
  vendorPayout       Decimal  @default(0.00) @db.Decimal(10, 2)
  refundAmount       Decimal  @default(0.00) @db.Decimal(10, 2)
  currency           String   @default("BDT")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model CustomerAnalytics {
  id                   Int      @id @default(autoincrement())
  totalCustomers       Int      @default(0)
  newCustomers         Int      @default(0)
  activeCustomers      Int      @default(0)
  returningCustomers   Int      @default(0)
  repeatBookingRate    Decimal  @default(0.00) @db.Decimal(5, 2)
  averageLifetimeValue Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model VendorAnalytics {
  id                   Int      @id @default(autoincrement())
  vendorId             Int      @unique
  vendor               Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  totalAssignments     Int      @default(0)
  completedAssignments Int      @default(0)
  cancelledAssignments Int      @default(0)
  acceptanceRate       Decimal  @default(0.00) @db.Decimal(5, 2)
  completionRate       Decimal  @default(0.00) @db.Decimal(5, 2)
  averageRating        Decimal  @default(0.00) @db.Decimal(3, 2)
  totalEarnings        Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ServiceAnalytics {
  id                 Int      @id @default(autoincrement())
  serviceId          Int      @unique
  service            Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  totalBookings      Int      @default(0)
  totalRevenue       Decimal  @default(0.00) @db.Decimal(10, 2)
  averagePrice       Decimal  @default(0.00) @db.Decimal(10, 2)
  mostSelectedOption String?
  averageRating      Decimal  @default(0.00) @db.Decimal(3, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PackageAnalytics {
  id             Int      @id @default(autoincrement())
  packageId      Int      @unique
  package        Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  totalBookings  Int      @default(0)
  totalRevenue   Decimal  @default(0.00) @db.Decimal(10, 2)
  conversionRate Decimal  @default(0.00) @db.Decimal(5, 2)
  averageRating  Decimal  @default(0.00) @db.Decimal(3, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ZoneAnalytics {
  id                 Int      @id @default(autoincrement())
  zoneId             Int      @unique
  zone               Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  totalBookings      Int      @default(0)
  totalRevenue       Decimal  @default(0.00) @db.Decimal(10, 2)
  totalCustomers     Int      @default(0)
  mostPopularService String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model EventAnalytics {
  id                  Int      @id @default(autoincrement())
  eventId             Int      @unique
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  totalBookings       Int      @default(0)
  mostSelectedPackage String?
  averageGuest        Int      @default(0)
  totalRevenue        Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PaymentAnalytics {
  id                 Int      @id @default(autoincrement())
  paymentMethod      String   @unique
  successfulPayments Int      @default(0)
  failedPayments     Int      @default(0)
  refundCount        Int      @default(0)
  totalCollection    Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PlatformReviewAnalytics {
  id              Int      @id @default(autoincrement())
  averageRating   Decimal  @default(0.00) @db.Decimal(3, 2)
  totalReviews    Int      @default(0)
  positiveReviews Int      @default(0)
  negativeReviews Int      @default(0)
  responseRate    Decimal  @default(0.00) @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MarketingAnalytics {
  id             Int      @id @default(autoincrement())
  campaignName   String   @unique
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  bookings       Int      @default(0)
  conversionRate Decimal  @default(0.00) @db.Decimal(5, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ConversionAnalytics {
  id                 Int      @id @default(autoincrement())
  visitors           Int      @default(0)
  calculatorStarted  Int      @default(0)
  quotationGenerated Int      @default(0)
  bookingsCompleted  Int      @default(0)
  conversionRate     Decimal  @default(0.00) @db.Decimal(5, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PerformanceAnalytics {
  id                    Int      @id @default(autoincrement())
  averageResponseTime   Decimal  @default(0.00) @db.Decimal(10, 2) // ms
  averageAssignmentTime Decimal  @default(0.00) @db.Decimal(10, 2) // hours
  averageCompletionTime Decimal  @default(0.00) @db.Decimal(10, 2) // hours
  systemUptime          Decimal  @default(100.00) @db.Decimal(5, 2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
