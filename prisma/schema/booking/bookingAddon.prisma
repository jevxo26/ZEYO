// ─────────────────────────────────────────────────────────────────────────────
// BookingAddon — add-ons per service (Drone, Live Printing, VIP Security)
// ─────────────────────────────────────────────────────────────────────────────

model BookingAddon {
  id               Int            @id @default(autoincrement())
  bookingServiceId Int
  bookingService   BookingService @relation(fields: [bookingServiceId], references: [id], onDelete: Cascade)
  addonId          Int?
  addon            ServiceAddon?  @relation(fields: [addonId], references: [id], onDelete: SetNull)
  addonName        String
  quantity         Int            @default(1)
  unitPrice        Decimal        @db.Decimal(12, 2)
  totalPrice       Decimal        @db.Decimal(12, 2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([bookingServiceId])
  @@index([addonId])
}
