// ─────────────────────────────────────────────────────────────────────────────
// BookingServiceConfiguration — e.g. Coverage=2 Days, Album=Yes, Drone=Yes
// ─────────────────────────────────────────────────────────────────────────────

model BookingServiceConfiguration {
  id                 Int            @id @default(autoincrement())
  bookingServiceId   Int
  bookingService     BookingService @relation(fields: [bookingServiceId], references: [id], onDelete: Cascade)
  configurationName  String
  configurationValue String
  additionalPrice    Decimal?       @db.Decimal(12, 2)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([bookingServiceId])
}
