model VendorGallery {
  id           Int              @id @default(autoincrement())
  vendorId     Int
  vendor       Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  portfolioId  Int?
  portfolio    VendorPortfolio? @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  imageUrl     String?
  videoUrl     String?
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([vendorId])
  @@index([portfolioId])
}
