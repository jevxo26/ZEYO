// ─────────────────────────────────────────────────────────────────────────────
// AssignmentItem — each BookingItem becomes one AssignmentItem
// status: pending | assigned | accepted | in_progress | completed | cancelled
// ─────────────────────────────────────────────────────────────────────────────

model AssignmentItem {
  id               Int              @id @default(autoincrement())
  assignmentId     Int
  assignment       VendorAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  bookingItemId    Int
  bookingItem      BookingItem      @relation(fields: [bookingItemId], references: [id])
  serviceId        Int
  service          Service          @relation(fields: [serviceId], references: [id])
  serviceName      String
  quantity         Int              @default(1)
  status           String           @default("pending")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  assignedVendors   AssignedVendor[]
  assignmentService AssignmentService?
  schedule          AssignmentSchedule?
  acceptances       VendorAcceptance[]
  workProgress      VendorWorkProgress[]
  checklist         WorkChecklist[]
  deliverables      Deliverable[]
  completionReport  CompletionReport?
  notes             AssignmentNote[]
  attachments       AssignmentAttachment[]
  replacements      VendorReplacement[]
  cancellation      AssignmentCancellation?
  commissions       VendorCommission[]

  @@index([assignmentId])
  @@index([bookingItemId])
  @@index([serviceId])
  @@index([status])
}
