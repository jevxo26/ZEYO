model VendorSetting {
  id                   Int      @id @default(autoincrement())
  vendorId             Int      @unique
  vendor               Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  autoAcceptAssignment Boolean  @default(false)
  notificationEnabled  Boolean  @default(true)
  emailNotification    Boolean  @default(true)
  smsNotification      Boolean  @default(true)
  pushNotification     Boolean  @default(true)
  workingHours         String? // e.g. JSON string describing daily schedule
  holidayMode          Boolean  @default(false)
  status               String   @default("active") // active | inactive
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
