// ─────────────────────────────────────────────────────────────────────────────
// AssignmentNote — internal notes per assignment item
// noteType: internal | vendor | admin
// ─────────────────────────────────────────────────────────────────────────────

model AssignmentNote {
  id               Int            @id @default(autoincrement())
  assignmentItemId Int
  assignmentItem   AssignmentItem @relation(fields: [assignmentItemId], references: [id], onDelete: Cascade)
  note             String
  noteType         String         @default("internal")
  createdBy        Int?
  createdByUser    User?          @relation("AssignmentNoteCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())

  @@index([assignmentItemId])
}
