model VendorProfile {
  id              Int      @id @default(autoincrement())
  vendorId        Int      @unique
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  about           String?
  experience      String?
  establishedYear Int?
  website         String?
  facebook        String?
  instagram       String?
  youtube         String?
  linkedin        String?
  officeAddress   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
