model VendorOwner {
  id          Int       @id @default(autoincrement())
  vendorId    Int       @unique
  vendor      Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String
  email       String
  nidNumber   String?
  dateOfBirth DateTime?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
