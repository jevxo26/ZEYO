// ─────────────────────────────────────────────────────────────────────────────
// CMS Module
// Content Management System for Banner, FAQ, Blog, Static Pages, Terms, Privacy, Contact.
// ─────────────────────────────────────────────────────────────────────────────

model Banner {
  id           Int       @id @default(autoincrement())
  title        String
  image        String
  redirectUrl  String?
  displayOrder Int       @default(0)
  startDate    DateTime?
  endDate      DateTime?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model FAQ {
  id           Int      @id @default(autoincrement())
  question     String
  answer       String   @db.Text
  category     String?
  displayOrder Int      @default(0)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Blog {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  thumbnail   String?
  content     String    @db.Text
  authorId    Int?
  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  status      String    @default("draft") // draft | published | archived
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model StaticPage {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  content   String   @db.Text
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TermsAndCondition {
  id            Int      @id @default(autoincrement())
  version       String
  content       String   @db.Text
  effectiveDate DateTime
  status        String   @default("active") // active | archived
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PrivacyPolicy {
  id            Int      @id @default(autoincrement())
  version       String
  content       String   @db.Text
  effectiveDate DateTime
  status        String   @default("active") // active | archived
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactInformation {
  id          Int      @id @default(autoincrement())
  companyName String
  email       String
  phone       String
  address     String?
  facebook    String?
  instagram   String?
  youtube     String?
  linkedin    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
