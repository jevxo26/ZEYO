model GeoLocation {
  id        Int      @id @default(autoincrement())
  zoneId    Int?
  zone      Zone?    @relation(fields: [zoneId], references: [id])
  latitude  Float
  longitude Float
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([zoneId])
}
