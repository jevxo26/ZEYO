// ─────────────────────────────────────────────────────────────────────────────
// EventPackageType Model
// Tier definitions for each event (Basic, Standard, Premium, Luxury)
// ─────────────────────────────────────────────────────────────────────────────

model EventPackageType {
  id           Int      @id @default(autoincrement())
  eventId      Int
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  packageType  String // e.g. basic | standard | premium | luxury
  description  String?
  displayOrder Int      @default(0)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventId])
  @@index([status])
  @@index([displayOrder])
}
