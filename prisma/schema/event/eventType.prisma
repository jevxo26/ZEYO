// ─────────────────────────────────────────────────────────────────────────────
// EventType Model
// Guest-count based type tiers within an event (Small, Medium, Large, etc.)
// ─────────────────────────────────────────────────────────────────────────────

model EventType {
  id           Int      @id @default(autoincrement())
  eventId      Int
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type         String // e.g. small | medium | large | corporate
  description  String?
  minimumGuest Int?
  maximumGuest Int?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventId])
  @@index([status])
}
