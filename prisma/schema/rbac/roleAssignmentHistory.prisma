// ─────────────────────────────────────────────────────────────────────────────
// RoleAssignmentHistory Model
// Immutable audit log of every role assignment change for a user.
// Captures who made the change, previous role, new role, and reason.
// ─────────────────────────────────────────────────────────────────────────────

model RoleAssignmentHistory {
  id           Int      @id @default(autoincrement())

  userId       Int                    // Target user whose role changed
  roleId       Int                    // The role involved in this event
  assignedBy   Int?                   // User ID who performed the action

  // ── Change Detail ──────────────────────────────────────────────────────────
  previousRole String?                // Previous role code / name
  newRole      String                 // New role code / name
  reason       String?                // Admin note or system reason

  // ── Timestamps ─────────────────────────────────────────────────────────────
  assignedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  // ── Relations ──────────────────────────────────────────────────────────────
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  // ── Indexes ────────────────────────────────────────────────────────────────
  @@index([userId])
  @@index([roleId])
  @@index([assignedBy])
  @@index([assignedAt])
}
