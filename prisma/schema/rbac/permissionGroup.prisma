// ─────────────────────────────────────────────────────────────────────────────
// PermissionGroup Model
// Logical grouping of related permissions for UI organisation and bulk
// assignment. e.g. "User Actions", "Financial Operations".
// ─────────────────────────────────────────────────────────────────────────────

model PermissionGroup {
  id           Int      @id @default(autoincrement())

  // ── Identity ───────────────────────────────────────────────────────────────
  name         String   @unique
  code         String   @unique   // e.g. USER_ACTIONS, FINANCIAL_OPS
  description  String?
  displayOrder Int      @default(0)

  // ── Status ─────────────────────────────────────────────────────────────────
  status       String   @default("active") // active | inactive

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // ── Indexes ────────────────────────────────────────────────────────────────
  @@index([code])
  @@index([status])
  @@index([displayOrder])
}
