// ─────────────────────────────────────────────────────────────────────────────
// Notification Queue — Dispatching and History
// ─────────────────────────────────────────────────────────────────────────────

model NotificationQueue {
  id             Int          @id @default(autoincrement())
  notificationId Int
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel        String // e.g., EMAIL, SMS, PUSH
  scheduledAt    DateTime?
  sentAt         DateTime?
  retryCount     Int          @default(0)
  status         String       @default("pending") // pending, processing, sent, failed
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([notificationId])
  @@index([status])
  @@index([scheduledAt])
}

model NotificationHistory {
  id             Int          @id @default(autoincrement())
  notificationId Int
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  customerId     Int?
  customer       Customer?    @relation("customerNotificationHistory", fields: [customerId], references: [id], onDelete: SetNull)
  channel        String
  deliveryStatus String // delivered, bounced, failed
  openedAt       DateTime?
  clickedAt      DateTime?
  createdAt      DateTime     @default(now())

  @@index([notificationId])
  @@index([customerId])
}
